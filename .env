APP_NAME=Gold Trading AI API
APP_VERSION=2.0.0
DEBUG=true
USE_MOCK_MODEL=false
SYMBOL=XAUUSD
DEFAULT_PERIOD=1mo
DEFAULT_INTERVAL=15m
MODEL_PATH=app/backtest/backend_model/xauusd_polygon_lstm_cv_final.keras
FEATURE_SCALER_PATH=app/backtest/backend_model/polygon_feature_scaler.pkl
PRICE_SCALER_PATH=app/backtest/backend_model/polygon_price_scaler.pkl
MODEL_SEQUENCE_LENGTH=60
MODEL_FEATURES=Close,News_Sentiment
MAX_POSITION_PCT=0.10
MAX_DRAWDOWN_LIMIT=0.05
KELLY_FRACTION=0.50
DEFAULT_CAPITAL=10000
NEWS_LOOKBACK_DAYS=3
NEWS_HEADLINE_LIMIT=8

LOG_API_URL = http://127.0.0.1:8000/api/logs
LOG_API_KEY = test123